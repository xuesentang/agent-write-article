# 应用配置
APP_NAME=自媒体爆款文章生成器
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/article.db

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LLM API 配置 (支持 OpenAI 兼容 API)
# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 智谱 GLM
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4

# 千问
QIANWEN_API_KEY=your_qianwen_api_key_here
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QIANWEN_MODEL=qwen-plus

# 默认使用的 LLM
DEFAULT_LLM_PROVIDER=deepseek

# 腾讯云 COS 配置
COS_SECRET_ID=your_secret_id_here
COS_SECRET_KEY=your_secret_key_here
COS_BUCKET=your_bucket_name_here
COS_REGION=ap-shanghai
COS_UPLOAD_PATH=article-images/

# 配图服务 API Keys
PEXELS_API_KEY=your_pexels_api_key_here
ICONIFY_API_URL=https://api.iconify.design

# Seedream AI 绘图配置
SEEDREAM_API_KEY=your_seedream_api_key_here
SEEDREAM_BASE_URL=https://api.seedream.ai/v1

# 前端配置（供后端参考）
FRONTEND_URL=http://localhost:5173