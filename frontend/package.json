{
  "name": "article-generator-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "generate-api": "openapi-typescript http://localhost:8000/openapi.json -o src/api/generated/schema.d.ts && npm run generate-api-client",
    "generate-api-client": "node scripts/generate-api-client.js"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "ant-design-vue": "^4.2.3",
    "axios": "^1.7.2",
    "markdown-it": "^14.1.0",
    "highlight.js": "^11.9.0",
    "@ant-design/icons-vue": "^7.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.6",
    "openapi-typescript": "^6.7.5",
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.12.7",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0"
  }
}